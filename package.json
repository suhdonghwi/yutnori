{
  "name": "hanpan-yutnori",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "clean": "node scripts/clean-dist.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prebuild": "pnpm clean",
    "build": "vite build",
    "preview": "vite preview",
    "test": "pnpm format:check && pnpm typecheck && pnpm test:rules && pnpm test:ai && pnpm build",
    "test:ai": "node --test tests/ai-player.test.mjs",
    "test:rules": "node --experimental-strip-types --test tests/yutnori-rules.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/rapier": "^2.2.0",
    "es-hangul": "^2.4.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "6.0.2",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "7.0.2",
    "vite": "^8.1.4"
  },
  "type": "module"
}
